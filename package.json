{
  "name": "beepbeepbeep-widget",
  "version": "1.2.1",
  "private": true,
  "description": "Desktop widget draft for the BeepBeepBeep study cards",
  "main": "electron-main.js",
  "scripts": {
    "cards:sync": "powershell -ExecutionPolicy Bypass -File ./scripts/update-cards-from-sheet.ps1",
    "cards:publish": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-cards-and-deploy.ps1",
    "desktop": "electron .",
    "desktop:dev": "electron . --dev",
    "desktop:build": "electron-builder --win nsis",
    "desktop:package": "electron-packager . \"BeepBeepBeep Widget\" --platform=win32 --arch=x64 --out=dist-portable --overwrite --asar --ignore=\"^/(dist|dist-portable|node_modules/\\.cache|\\.git|\\.vercel|WebBeepBeep)\""
  },
  "devDependencies": {
    "@electron/packager": "^18.3.6",
    "electron": "^37.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.beepbeepbeep.widget",
    "productName": "BeepBeepBeep Widget",
    "files": [
      "index.html",
      "app.js",
      "styles.css",
      "electron-main.js",
      "electron-preload.js",
      "data/**/*",
      "audio/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}


